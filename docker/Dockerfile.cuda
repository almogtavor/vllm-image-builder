# Build a custom vLLM image from any fork/branch.
#
# Uses the same approach as vllm-project/vllm's official Dockerfile:
# NVIDIA CUDA base image + precompiled CUDA kernels (works when
# your fork's changes are Python-only).

ARG CUDA_VERSION=12.4.1
ARG PYTHON_VERSION=3.11

FROM nvidia/cuda:${CUDA_VERSION}-devel-ubuntu22.04

LABEL org.opencontainers.image.source=https://github.com/almogtavor/vllm-image-builder
LABEL org.opencontainers.image.description="Custom vLLM image built from fork"
LABEL org.opencontainers.image.licenses="Apache-2.0"

ARG CUDA_VERSION
ARG PYTHON_VERSION

ENV DEBIAN_FRONTEND=noninteractive

# System dependencies
RUN apt-get update -y \
    && apt-get install -y --no-install-recommends \
        software-properties-common \
        git \
        curl \
        ccache \
        libibverbs-dev \
    && add-apt-repository ppa:deadsnakes/ppa -y \
    && apt-get update -y \
    && apt-get install -y --no-install-recommends \
        python${PYTHON_VERSION} \
        python${PYTHON_VERSION}-dev \
        python${PYTHON_VERSION}-venv \
    && rm -rf /var/lib/apt/lists/*

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Create virtual environment
RUN uv venv /opt/vllm --python ${PYTHON_VERSION}
ENV PATH="/opt/vllm/bin:$PATH"
ENV VIRTUAL_ENV="/opt/vllm"

# uv settings
ENV UV_HTTP_TIMEOUT=500
ENV UV_INDEX_STRATEGY="unsafe-best-match"
ENV UV_LINK_MODE=copy

# CUDA compatibility
RUN echo "/usr/local/cuda-$(echo $CUDA_VERSION | cut -d. -f1,2)/compat/" \
    > /etc/ld.so.conf.d/cuda-compat.conf && ldconfig

# Clone the configured vllm fork
ARG VLLM_REPO=https://github.com/almogtavor/vllm.git
ARG VLLM_BRANCH=segmented-spans
ARG VLLM_BASE_COMMIT

WORKDIR /opt/vllm-source
RUN git clone ${VLLM_REPO} . && cd vllm && git checkout ${VLLM_BRANCH} && cd ..

# Install PyTorch + vllm dependencies
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install -r requirements/cuda.txt \
    --extra-index-url https://download.pytorch.org/whl/cu$(echo ${CUDA_VERSION} | cut -d. -f1,2 | tr -d '.')

# Install vllm with precompiled CUDA kernels
# Download pre-built .so files from wheels.vllm.ai for the upstream base
# commit our fork is based on (works when fork changes are Python-only).
ENV SETUPTOOLS_SCM_PRETEND_VERSION="0.0.0+custom"
RUN uv pip install setuptools-scm
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=cache,target=/root/.cache/pip \
    uv pip install -e . --no-build-isolation

# Runtime environment
ENV VLLM_USAGE_SOURCE=production-docker-image \
    VLLM_WORKER_MULTIPROC_METHOD=fork \
    OUTLINES_CACHE_DIR=/tmp/outlines \
    NUMBA_CACHE_DIR=/tmp/numba \
    TRITON_CACHE_DIR=/tmp/triton \
    VLLM_CACHE_ROOT=/tmp/vllm

ENTRYPOINT ["python3", "-m", "vllm.entrypoints.openai.api_server"]
