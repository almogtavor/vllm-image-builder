FROM python:3.12-slim

LABEL org.opencontainers.image.source=https://github.com/almogtavor/vllm-image-builder
LABEL org.opencontainers.image.description="Spans middleware for vLLM"
LABEL org.opencontainers.image.licenses="Apache-2.0"

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    openai \
    transformers \
    pyyaml

COPY middleware/ /app/

EXPOSE 8080

ENTRYPOINT ["uvicorn", "spans_middleware:app", "--host", "0.0.0.0", "--port", "8080"]
